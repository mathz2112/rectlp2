<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.HBox?>
<?import java.lang.String?>

<VBox alignment="CENTER" style="-fx-background-color: white;" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.rec1.SecondaryController">

    <children>

        <Label style="-fx-text-fill: black; -fx-font-size: 20px;" text="Cadastrar"/>

        <TextField fx:id="getNome"
                   promptText="Nome"/>

        <TextField fx:id="getEmail"
                   promptText="Email"/>

        <TextField fx:id="getCodigo"
                   promptText="Código de acesso"/>

        <ComboBox fx:id="categoria"
                  promptText="Selecione">

            <items>

                <FXCollections fx:factory="observableArrayList">

                    <String fx:value="Estudante"/>
                    <String fx:value="Professor"/>

                </FXCollections>

            </items>

        </ComboBox>

        <CheckBox fx:id="termo" text="Aceitar todos os termos"/>

        <HBox spacing="20">

            <Button text="Salvar"
                    style="-fx-background-color: green; -fx-text-fill: white;"
                    onAction="#salvar"/>

            <Button text="Voltar"
                    style="-fx-background-color: green; -fx-text-fill: white;"
                    onAction="#voltar"/> 

        </HBox>


    </children>

    <padding>
        <Insets bottom="20.0"
                left="20.0"
                right="20.0"
                top="20.0" />
    </padding>


</VBox>