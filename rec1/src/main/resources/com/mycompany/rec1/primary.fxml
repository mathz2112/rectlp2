<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.rec1.PrimaryController">
    <children>

        <Label text="Biblioteca Digital"/>

        <TextField fx:id="getemail"
                   promptText="Email"/>

        <TextField fx:id="getcodigo"
                   promptText="Código de acesso"/>

        <HBox alignment="CENTER"
              spacing="20">

            <Button text="Entrar"
                    onAction="#entrar"/>

            <Button text="Cadastrar"
                    onAction="#cadastrar"/>

            <Button text="Recuperar acesso"
                    onAction="#recuperar"/>

        </HBox>

    </children>

    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

</VBox>