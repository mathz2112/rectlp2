<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" style="-fx-background-color: #7CA37C;" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.rec1.PrimaryController">

    <children>

        <Label style="-fx-text-fill: black; -fx-font-size: 20px;" text="Biblioteca Digital" />

        <TextField fx:id="getemail"
                   style="-fx-background-color: white; -fx-text-fill: grey;"
                   promptText="Email"/>

        <TextField fx:id="getcodigo"
                   style="-fx-background-color: white; -fx-text-fill: grey;"
                   promptText="Código de acesso"/>

        <HBox spacing="30" alignment="CENTER">

            <Button style="-fx-background-color: green; -fx-text-fill: white;"
                    text="Entrar"
                    onAction="#entrar"/>

            <Button style="-fx-background-color: green; -fx-text-fill: white;"
                    text="Cadastrar"
                    onAction="#cadastrar"/>

            <Button style="-fx-background-color: green; -fx-text-fill: white;"
                    text="Recuperar acesso"
                    onAction="#recuperar"/>

        </HBox>

    </children>

    <padding>
        <Insets bottom="20.0"
                left="20.0"
                right="20.0"
                top="20.0" />
    </padding>

</VBox>
