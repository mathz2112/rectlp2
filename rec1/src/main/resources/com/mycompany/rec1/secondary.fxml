<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.rec1.SecondaryController">
    <children>

        <Label text="Cadastro de Leitor"
                style="-fx-font-size: 30px; -fx-font-weight: bold;"/>

        <TextField fx:id="getNome"
                   promptText="Nome"/>

        <TextField fx:id="getEmail"
                   promptText="Email"/>

        <TextField fx:id="getCodigo"
                   promptText="Código de acesso"/>

        <ComboBox fx:id="categoria"
                  promptText="Selecione a categoria"/>

        <CheckBox fx:id="termo"
                  text="Aceito os termos"/>

        <HBox alignment="CENTER"
              spacing="20">

            <Button text="Salvar"
                    style="-fx-background-color: green; -fx-text-fill: white;"
                    onAction="#salvar"/>

            <Button text="Voltar"
                    style="-fx-background-color: green; -fx-text-fill: white;"
                    onAction="#voltar"/>

        </HBox>

    </children>

    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

</VBox>