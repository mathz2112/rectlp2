<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" style="-fx-background-color: #7CA37C;" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.rec1.TertieryController">

    <children>

        <Label style="-fx-text-fill: black; -fx-font-size: 20px;" text="Recuperar senha"/>

        <TextField fx:id="getemail"
                   promptText="Email"/>

        <HBox spacing="30" alignment="CENTER">

            <Button text="Recuperar acesso"
                    style="-fx-background-color: green; -fx-text-fill: white;"
                    onAction="#recuperar"/>

            <Button text="Fechar"
                    style="-fx-background-color: green; -fx-text-fill: white;"
                    onAction="#fechar"/>

        </HBox>

    </children>

    <padding>

        <Insets bottom="20.0"
                left="20.0"
                right="20.0"
                top="20.0" />
    </padding>

</VBox>
