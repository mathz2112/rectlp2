<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.rec1.TertieryController">
    <children>

        <Label text="Recuperar Acesso"/>

        <TextField fx:id="getemail"
                   promptText="Informe seu email"/>

        <HBox alignment="CENTER"
              spacing="20">

            <Button text="Recuperar"
                    onAction="#recuperar"/>

            <Button text="Fechar"
                    onAction="#fechar"/>

        </HBox>

    </children>

    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

</VBox>